{
  "manifest_version": 3,
  "name": "Mirra",
  "description": "Digital wellbeing companion — mindful social media use",
  "version": "1.0.0",

  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],

  "host_permissions": [
    "*://www.instagram.com/*",
    "*://www.tiktok.com/*",
    "*://www.youtube.com/*",
    "https://api.elevenlabs.io/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": [
        "*://www.instagram.com/*",
        "*://www.tiktok.com/*",
        "*://www.youtube.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],

  "action": {
    "default_popup": "popup.html",
    "default_title": "Mirra"
  }
}