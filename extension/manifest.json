{
  "manifest_version": 3,
  "name": "Mirra",
  "description": "Not your standard app blocker. Just checking in.",
  "version": "1.0.0",

  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],

  "host_permissions": [
    "*://www.instagram.com/*",
    "*://www.tiktok.com/*",
    "*://www.youtube.com/*",
    "https://api.elevenlabs.io/*",
    "https://api.hume.ai/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": [
        "*://www.instagram.com/*",
        "*://www.tiktok.com/*",
        "*://www.youtube.com/*"
      ],
      "js": ["config.js", "hume.js", "content.js"],
      "run_at": "document_start"
    }
  ],

  "action": {
    "default_popup": "popup.html",
    "default_title": "Mirra"
  }
}